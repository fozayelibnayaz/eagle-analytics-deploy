# ═══════════════════════════════════════════════════════════════
# Eagle 3D Streaming — Analytics Hub
# EXAMPLE SECRETS — copy relevant values into .streamlit/secrets.toml
# NEVER commit real secrets. .streamlit/secrets.toml is gitignored.
# ═══════════════════════════════════════════════════════════════

# ── Database (MongoDB LOCAL only, no cloud) ──
MONGO_URI = "mongodb://localhost:27017"
MONGO_DB  = "eagle3d"

# ── App password gate ──
APP_PASSWORD = "your-secure-password-here"

# ── Persistent login sessions (7-day cookies) ──
COOKIE_SECRET = "<run: python3 -c 'import secrets; print(secrets.token_urlsafe(48))'>"
COOKIE_NAME   = "e3d_auth"
COOKIE_DAYS   = 7

# ── AI providers (at least one required) ──
GROQ_API_KEY   = "gsk_..."      # from console.groq.com
GEMINI_API_KEY = "AI..."        # from aistudio.google.com

# ── Telegram alerts (optional) ──
TELEGRAM_BOT_TOKEN = "123456:ABC..."
TELEGRAM_CHAT_ID   = "-1001234567890"

# ── Email alerts (optional) ──
EMAIL_FROM         = "you@gmail.com"
EMAIL_TO           = "team@example.com"
EMAIL_APP_PASSWORD = "app-specific-password"

# ── Google Analytics 4 ──
GA4_PROPERTY_ID = "374525971"

# ── KPI Dashboard scraper ──
KPI_EMAIL    = "your-kpi-login@example.com"
KPI_PASSWORD = "..."

# ── YouTube ──
YOUTUBE_API_KEY    = "AIza..."
YOUTUBE_CHANNEL_ID = "UC..."

# ── LinkedIn (paste cookies JSON as single-line string) ──
LINKEDIN_COMPANY_PAGE = "eagle-3d-streaming"
LINKEDIN_COOKIES_JSON = '[{"name":"li_at","value":"...","domain":".linkedin.com"}]'

# ── Stripe (cookie scraping) ──
STRIPE_COOKIES_JSON  = '[{"name":"session","value":"...","domain":"dashboard.stripe.com"}]'
STRIPE_CUSTOMERS_URL = "https://dashboard.stripe.com/customers?has_subscription=true"

# ── Google service account (put full JSON as TOML table) ──
[GOOGLE_CREDS]
type          = "service_account"
project_id    = "your-project"
private_key   = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email  = "sa@project.iam.gserviceaccount.com"
# ... (all fields from downloaded JSON)

[ga4_service_account]
# Same content as [GOOGLE_CREDS] — GA4 connector expects this exact key
type          = "service_account"
# ...
