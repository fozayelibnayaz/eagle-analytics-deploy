frot Path
import re

content = Path(".streamlit/secrets.toml").read_text()
m = re.search(r'^API_KEY\s*=\s*"([^"]+)"', content, re.MULTILINE)
API_KEY = m.group(1) if m else "MISSING"
BASE = "https://unsoiling-tendenciously-marge.ngrok-free.dev"

lines = []
lines.append("# Webhook Integration Guide")
lines.append("")
lines.append("**For:** Aninda Sadman (Backend Developer)")
lines.append("**Direction:** Your backend POSTs data to Fozayel's API.")
lines.append("**Purpose:** Real-time sync of signups/uploads/payments to the analytics dashboard.")
lines.append("")
lines.append("---")
lines.append("")
lines.append("## TL;DR")
lines.append("")
lines.append("Whenever signup / upload / payment happens in your backend, POST it:")
lines.append("")
lines.append("```")
lines.append(f"POST {BASE}/webhook")
lines.append(f"Header: X-API-Key: {API_KEY}")
lines.append("Body:   JSON (see below)")
lines.append("```")
lines.append("")
lines.append("Data appears in dashboard within 1 second. Telegram alert fires per call.")
lines.append("")
lines.append("---")
lines.append("")
lines.append("## Endpoint")
lines.append("")
lines.append(f"- **URL:** `{BASE}/webhook`")
lines.append("- **Method:** POST")
lines.append(f"- **Auth header:** `X-API-Key: {API_KEY}`")
lines.append("- **Content-Type:** `application/json`")
lines.append("")
lines.append("## Request Body Schema")
lines.append("")
lines.append("```json")
lines.append("{")
lines.append('  "source": "your-backend-name",')
lines.append('  "data": [')
lines.append('    { "type": "signup",  "info": { ... } },')
lines.append('    { "type": "upload",  "info": { ... } },')
lines.append('    { "type": "payment", "info": { ... } }')
lines.append("  ]")
lines.append("}")
lines.append("```")
lines.append("")
lines.append("Send 1 item or 100 items per call. Array is processed atomically.")
lines.append("")
lines.append("## Item Types")
lines.append("")
lines.append("### signup")
lines.append("")
lines.append("```json")
lines.append("{")
lines.append('  "type": "signup",')
lines.append('  "info": {')
lines.append('    "id":          "unique-id-from-your-system",')
lines.append('    "email":       "user@example.com",')
lines.append('    "username":    "optional",')
lines.append('    "signup_date": "2026-07-13",')
lines.append('    "lead_source": "google | linkedin | chatgpt | youtube | direct | other",')
lines.append('    "phone":       "optional"')
lines.append("  }")
lines.append("}")
lines.append("```")
lines.append("")
lines.append("Required: `email`. Recommended: `id`, `signup_date`, `lead_source`.")
lines.append("")
lines.append("### upload")
lines.append("")
lines.append("```json")
lines.append("{")
