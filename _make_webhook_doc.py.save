lines.append('    "id":          "unique-id-from-your-system",')
lines.append('    "email":       "user@example.com",')
lines.append('    "upload_date": "2026-07-13",')
lines.append('    "app_name":    "optional",')
lines.append('    "username":    "optional"')
lines.append("  }")
lines.append("}")
lines.append("```")
lines.append("")
lines.append("Required: `email`. Recommended: `id`, `upload_date`, `app_name`.")
